@inherits ReactiveComponentBase<ReceiverViewModel>
@page "/"
@inject IJSRuntime JSRuntime

<PageTitle>USB Prison</PageTitle>

<h1>Hello, world!</h1>

Welcome to your new app.

@if (ViewModel != null)
{
    @foreach (var group in ViewModel.GroupedDevices)
    {
        @group.Name
        @foreach(var item in group)
        {
            <div>
                @item.DisplayName
            </div>
        }
    }
}

@code {

    public Home()
    {
         ViewModel = new ReceiverViewModel(true );
    }

    protected override void OnAfterRender(bool firstRender)
    {
        base.OnAfterRender(firstRender);
        if (firstRender)
        {
           ViewModel!.InitializeJS(JSRuntime);
        }
    }
}