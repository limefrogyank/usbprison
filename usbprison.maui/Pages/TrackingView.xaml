<?xml version="1.0" encoding="utf-8" ?>
<rxui:ReactiveContentPage
    x:Class="usbprison.maui.Pages.TrackingView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:data="clr-namespace:Syncfusion.Maui.DataSource;assembly=Syncfusion.Maui.DataSource"
    xmlns:local="clr-namespace:usbprison.maui.Pages"
    xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
    xmlns:rxui="clr-namespace:ReactiveUI.Maui;assembly=ReactiveUI.Maui"
    xmlns:sflist="clr-namespace:Syncfusion.Maui.ListView;assembly=Syncfusion.Maui.ListView"
    xmlns:vm="clr-namespace:usbprison;assembly=usbprison.lib"
    Title="Tracked Devices"
    x:DataType="{x:Type vm:TrackingViewModel}"
    x:TypeArguments="vm:TrackingViewModel">
    <Grid>
        <sflist:SfListView ItemsSource="{Binding TrackedDevices}" SelectionMode="None">
            <!--<sflist:SfListView.DataSource>
                <data:DataSource>
                    <data:DataSource.GroupDescriptors>
                        <data:GroupDescriptor PropertyName="IsPluggedIn" />
                    </data:DataSource.GroupDescriptors>
                </data:DataSource>
            </sflist:SfListView.DataSource>-->
            <!--<CollectionView.GroupHeaderTemplate>
                <DataTemplate>
                    <Label Style="{StaticResource Title1}" Text="{Binding Name}" />
                </DataTemplate>
            </CollectionView.GroupHeaderTemplate>-->
            <sflist:SfListView.HeaderTemplate>
                <DataTemplate>
                    <Grid Margin="5" ColumnDefinitions="2*, *, 50">
                        <Label FontAttributes="Bold" Text="Device Name/Id" />
                        <Label
                            Grid.Column="1"
                            FontAttributes="Bold"
                            Text="Is Plugged In" />
                    </Grid>
                </DataTemplate>
            </sflist:SfListView.HeaderTemplate>
            <sflist:SfListView.ItemTemplate>
                <DataTemplate x:DataType="vm:TrackedDeviceViewModel">

                    <Grid
                        Margin="5"
                        ColumnDefinitions="2*, *, 50"
                        RowDefinitions="*,*">

                        <Label Text="{Binding DisplayName}" />
                        <Label
                            Grid.Row="1"
                            Style="{StaticResource Caption2}"
                            Text="{Binding Device.Id}" />

                        <Label
                            Grid.RowSpan="2"
                            Grid.Column="1"
                            Text="{Binding IsPluggedIn}" />

                        <ImageButton
                            Grid.RowSpan="2"
                            Grid.Column="2"
                            Command="{Binding RemoveCommand}"
                            Source="{mi:Material Icon=DeleteForever,
                                                 IconColor={AppThemeBinding Dark=White,
                                                                            Light=Gray}}" />
                    </Grid>

                </DataTemplate>
            </sflist:SfListView.ItemTemplate>
        </sflist:SfListView>
    </Grid>
</rxui:ReactiveContentPage>