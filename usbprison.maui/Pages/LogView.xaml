<?xml version="1.0" encoding="utf-8" ?>
<rxui:ReactiveContentPage
    x:Class="usbprison.maui.Pages.LogView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:usbprison"
    xmlns:model="clr-namespace:usbprison;assembly=usbprison.lib"
    xmlns:rxui="clr-namespace:ReactiveUI.Maui;assembly=ReactiveUI.Maui"
    xmlns:sflist="clr-namespace:Syncfusion.Maui.ListView;assembly=Syncfusion.Maui.ListView"
    xmlns:vm="clr-namespace:usbprison;assembly=usbprison.lib"
    Title="USB Prison"
    x:DataType="{x:Type vm:LogViewModel}"
    x:TypeArguments="vm:LogViewModel">
    <Grid RowDefinitions="Auto,Auto,*">
        <Label Text="Daily Log" />
        <Label Grid.Row="1" Text="{Binding DateStr}" />
        <Editor
            Grid.Row="2"
            AutoSize="TextChanges"
            IsReadOnly="True"
            Placeholder="Log Contents goes here..."
            Text="{Binding LogContents, Mode=OneWay}" />

    </Grid>
</rxui:ReactiveContentPage>