<?xml version="1.0" encoding="utf-8" ?>
<rxui:ReactiveContentPage
    x:Class="usbprison.maui.Pages.ReceiverView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:usbprison"
    xmlns:model="clr-namespace:usbprison;assembly=usbprison.lib"
    xmlns:rxui="clr-namespace:ReactiveUI.Maui;assembly=ReactiveUI.Maui"
    xmlns:sflist="clr-namespace:Syncfusion.Maui.ListView;assembly=Syncfusion.Maui.ListView"
    xmlns:vm="clr-namespace:usbprison;assembly=usbprison.lib"
    Title="USB Prison"
    x:DataType="{x:Type vm:ReceiverViewModel}"
    x:TypeArguments="vm:ReceiverViewModel">
    <ContentPage.ToolbarItems>
        <ToolbarItem Clicked="ToolbarItem_Clicked" Text="Log" />
    </ContentPage.ToolbarItems>
    <Grid RowDefinitions="Auto,Auto,*">
        <Label Text="Listening for incoming messages..." />
        <Editor
            Grid.Row="1"
            AutoSize="TextChanges"
            IsReadOnly="True"
            Placeholder="Receiver text goes here..."
            Text="{Binding LatestMessage, Mode=TwoWay}" />
        <sflist:SfListView
            Grid.Row="2"
            ItemsSource="{Binding Devices}"
            SelectionMode="None">
            <sflist:SfListView.HeaderTemplate>
                <DataTemplate>
                    <Grid Margin="5" ColumnDefinitions="*, *">
                        <Label FontAttributes="Bold" Text="Device Name" />
                        <Label
                            Grid.Column="1"
                            FontAttributes="Bold"
                            Text="Unique Id" />
                    </Grid>
                </DataTemplate>
            </sflist:SfListView.HeaderTemplate>
            <sflist:SfListView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="*,*">
                        <Label Text="{Binding DisplayName}" />
                        <Label Grid.Column="1" Text="{Binding Device.SerialNumber}" />
                    </Grid>
                </DataTemplate>
            </sflist:SfListView.ItemTemplate>
        </sflist:SfListView>
    </Grid>
</rxui:ReactiveContentPage>