<?xml version="1.0" encoding="utf-8" ?>
<rxui:ReactiveContentPage
    x:Class="usbprison.maui.Pages.ReportView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:usbprison"
    xmlns:model="clr-namespace:usbprison;assembly=usbprison.lib"
    xmlns:rxui="clr-namespace:ReactiveUI.Maui;assembly=ReactiveUI.Maui"
    xmlns:sflist="clr-namespace:Syncfusion.Maui.ListView;assembly=Syncfusion.Maui.ListView"
    xmlns:vm="clr-namespace:usbprison;assembly=usbprison.lib"
    Title="Reports"
    x:DataType="{x:Type vm:ReportViewModel}"
    x:TypeArguments="vm:ReportViewModel">
    <Grid RowDefinitions="Auto,Auto,*">
        <Label Style="{StaticResource Title2}" Text="Daily Log" />
        <!--<Label Grid.Row="1" Text="Test" />-->
        <CollectionView
            Grid.Row="2"
            IsGrouped="True"
            ItemsSource="{Binding GroupedLogs}">
            <CollectionView.GroupHeaderTemplate>
                <DataTemplate>
                    <Label
                        Padding="0,5,0,0"
                        Style="{StaticResource Title3}"
                        Text="{Binding Name}" />
                </DataTemplate>
            </CollectionView.GroupHeaderTemplate>
            <!--<CollectionView.HeaderTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="*,*">
                        <Label Text="Timestamp" />
                        <Label Grid.Column="1" Text="Status" />
                    </Grid>
                </DataTemplate>
            </CollectionView.HeaderTemplate>-->
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="10,0" ColumnDefinitions="*,*">
                        <Label Text="{Binding LocalDateTime}" />
                        <Label Grid.Column="1" Text="{Binding PrisonLog.Status}" />
                    </Grid>

                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</rxui:ReactiveContentPage>